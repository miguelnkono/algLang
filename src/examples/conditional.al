
Algorithm: simpleConditional;
Variables:
    name: string;
    age: integer;
    height: real;
Begin:
    name <- "Arshi";
    age <- 20;
    height <- 1.80;
    if name == "Arshi" then:
        write("your information: ");
        write("name: " + name);
        write("age: " + age);
        write("height: " + height);
    endif
End
